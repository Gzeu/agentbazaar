{
  "name": "escrow",
  "endpoints": [
    {
      "name": "init",
      "onlyOwner": true,
      "inputs": [
        {"name": "task_timeout_seconds", "type": "u64"},
        {"name": "marketplace_fee_bps", "type": "u64"}
      ],
      "outputs": []
    },
    {
      "name": "createTask",
      "mutability": "mutable",
      "payableInTokens": ["EGLD"],
      "inputs": [
        {"name": "task_id", "type": "bytes"},
        {"name": "service_id", "type": "bytes"},
        {"name": "provider", "type": "Address"},
        {"name": "payload_hash", "type": "bytes"}
      ],
      "outputs": []
    },
    {
      "name": "releaseEscrow",
      "mutability": "mutable",
      "inputs": [
        {"name": "task_id", "type": "bytes"},
        {"name": "proof_hash", "type": "bytes"}
      ],
      "outputs": []
    },
    {
      "name": "refundTask",
      "mutability": "mutable",
      "inputs": [{"name": "task_id", "type": "bytes"}],
      "outputs": []
    },
    {
      "name": "openDispute",
      "mutability": "mutable",
      "inputs": [
        {"name": "task_id", "type": "bytes"},
        {"name": "reason", "type": "bytes"}
      ],
      "outputs": []
    },
    {
      "name": "resolveDispute",
      "onlyOwner": true,
      "mutability": "mutable",
      "inputs": [
        {"name": "task_id", "type": "bytes"},
        {"name": "in_favor_of_buyer", "type": "bool"}
      ],
      "outputs": []
    },
    {
      "name": "getTask",
      "mutability": "readonly",
      "inputs": [{"name": "task_id", "type": "bytes"}],
      "outputs": [{"type": "optional<TaskRecord>", "multi_result": true}]
    },
    {
      "name": "getTaskTimeoutSeconds",
      "mutability": "readonly",
      "inputs": [],
      "outputs": [{"type": "u64"}]
    },
    {
      "name": "getMarketplaceFeeBps",
      "mutability": "readonly",
      "inputs": [],
      "outputs": [{"type": "u64"}]
    }
  ],
  "types": {
    "TaskStatus": {
      "type": "enum",
      "variants": [
        {"name": "Pending", "discriminant": 0},
        {"name": "Running", "discriminant": 1},
        {"name": "Completed", "discriminant": 2},
        {"name": "Refunded", "discriminant": 3},
        {"name": "Disputed", "discriminant": 4}
      ]
    },
    "TaskRecord": {
      "type": "struct",
      "fields": [
        {"name": "service_id", "type": "bytes"},
        {"name": "buyer", "type": "Address"},
        {"name": "provider", "type": "Address"},
        {"name": "amount", "type": "BigUint"},
        {"name": "status", "type": "TaskStatus"},
        {"name": "payload_hash", "type": "bytes"},
        {"name": "proof_hash", "type": "bytes"},
        {"name": "created_at", "type": "u64"},
        {"name": "timeout_at", "type": "u64"},
        {"name": "completed_at", "type": "u64"}
      ]
    }
  },
  "events": [
    {
      "identifier": "TaskCreated",
      "inputs": [
        {"name": "task_id", "type": "bytes", "indexed": true},
        {"name": "buyer", "type": "Address", "indexed": true},
        {"name": "provider", "type": "Address", "indexed": true}
      ]
    },
    {
      "identifier": "TaskCompleted",
      "inputs": [
        {"name": "task_id", "type": "bytes", "indexed": true},
        {"name": "provider", "type": "Address", "indexed": true},
        {"name": "proof_hash", "type": "bytes"}
      ]
    },
    {"identifier": "TaskRefunded", "inputs": [{"name": "task_id", "type": "bytes", "indexed": true}, {"name": "buyer", "type": "Address", "indexed": true}]},
    {"identifier": "DisputeOpened", "inputs": [{"name": "task_id", "type": "bytes", "indexed": true}, {"name": "buyer", "type": "Address", "indexed": true}, {"name": "reason", "type": "bytes"}]},
    {"identifier": "DisputeResolved", "inputs": [{"name": "task_id", "type": "bytes", "indexed": true}, {"name": "winner", "type": "Address", "indexed": true}, {"name": "in_favor_of_buyer", "type": "bool"}]}
  ]
}
