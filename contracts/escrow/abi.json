{
  "name": "EscrowContract",
  "constructor": {
    "inputs": [
      {"name": "registry_address", "type": "Address"},
      {"name": "reputation_address", "type": "Address"}
    ],
    "outputs": []
  },
  "endpoints": [
    {
      "name": "createTask",
      "mutability": "mutable",
      "payableInTokens": ["EGLD"],
      "inputs": [
        {"name": "task_id", "type": "bytes"},
        {"name": "service_id", "type": "bytes"},
        {"name": "provider", "type": "Address"},
        {"name": "payload_hash", "type": "bytes"}
      ],
      "outputs": []
    },
    {
      "name": "releaseEscrow",
      "mutability": "mutable",
      "inputs": [
        {"name": "task_id", "type": "bytes"},
        {"name": "proof_hash", "type": "bytes"}
      ],
      "outputs": []
    },
    {
      "name": "refundTask",
      "mutability": "mutable",
      "inputs": [{"name": "task_id", "type": "bytes"}],
      "outputs": []
    },
    {
      "name": "openDispute",
      "mutability": "mutable",
      "inputs": [
        {"name": "task_id", "type": "bytes"},
        {"name": "reason", "type": "bytes"}
      ],
      "outputs": []
    },
    {
      "name": "resolveDispute",
      "mutability": "mutable",
      "inputs": [
        {"name": "task_id", "type": "bytes"},
        {"name": "winner", "type": "Address"}
      ],
      "outputs": []
    }
  ],
  "views": [
    {
      "name": "getTask",
      "mutability": "readonly",
      "inputs": [{"name": "task_id", "type": "bytes"}],
      "outputs": [{"type": "optional<TaskRecord>", "multi_result": true}]
    },
    {
      "name": "getTaskStatus",
      "mutability": "readonly",
      "inputs": [{"name": "task_id", "type": "bytes"}],
      "outputs": [{"type": "optional<TaskStatus>", "multi_result": true}]
    },
    {
      "name": "taskExists",
      "mutability": "readonly",
      "inputs": [{"name": "task_id", "type": "bytes"}],
      "outputs": [{"type": "bool"}]
    }
  ],
  "types": {
    "TaskStatus": {
      "type": "enum",
      "variants": [
        {"name": "Pending", "discriminant": 0},
        {"name": "Completed", "discriminant": 1},
        {"name": "Refunded", "discriminant": 2},
        {"name": "Disputed", "discriminant": 3}
      ]
    },
    "TaskRecord": {
      "type": "struct",
      "fields": [
        {"name": "buyer", "type": "Address"},
        {"name": "provider", "type": "Address"},
        {"name": "service_id", "type": "bytes"},
        {"name": "amount", "type": "BigUint"},
        {"name": "status", "type": "TaskStatus"},
        {"name": "payload_hash", "type": "bytes"},
        {"name": "proof_hash", "type": "bytes"},
        {"name": "created_at", "type": "u64"},
        {"name": "completed_at", "type": "u64"}
      ]
    }
  }
}
