{
  "name": "ReputationContract",
  "constructor": {
    "inputs": [{"name": "escrow_address", "type": "Address"}],
    "outputs": []
  },
  "endpoints": [
    {
      "name": "submitCompletionProof",
      "mutability": "mutable",
      "inputs": [
        {"name": "task_id", "type": "bytes"},
        {"name": "proof_hash", "type": "bytes"},
        {"name": "latency_ms", "type": "u64"}
      ],
      "outputs": []
    },
    {
      "name": "recordFailure",
      "mutability": "mutable",
      "inputs": [
        {"name": "provider", "type": "Address"},
        {"name": "task_id", "type": "bytes"}
      ],
      "outputs": []
    },
    {
      "name": "slashProvider",
      "mutability": "mutable",
      "inputs": [
        {"name": "provider", "type": "Address"},
        {"name": "task_id", "type": "bytes"},
        {"name": "reason", "type": "bytes"}
      ],
      "outputs": []
    }
  ],
  "views": [
    {
      "name": "getReputation",
      "mutability": "readonly",
      "inputs": [{"name": "provider", "type": "Address"}],
      "outputs": [{"type": "ReputationRecord"}]
    },
    {
      "name": "getScore",
      "mutability": "readonly",
      "inputs": [{"name": "provider", "type": "Address"}],
      "outputs": [{"type": "u64"}]
    },
    {
      "name": "getCompletedTasks",
      "mutability": "readonly",
      "inputs": [{"name": "provider", "type": "Address"}],
      "outputs": [{"type": "u64"}]
    }
  ],
  "types": {
    "ReputationRecord": {
      "type": "struct",
      "fields": [
        {"name": "score", "type": "u64"},
        {"name": "completed_tasks", "type": "u64"},
        {"name": "failed_tasks", "type": "u64"},
        {"name": "disputed_tasks", "type": "u64"},
        {"name": "total_latency_ms", "type": "u64"},
        {"name": "last_proof_hash", "type": "bytes"},
        {"name": "last_updated", "type": "u64"}
      ]
    }
  }
}
