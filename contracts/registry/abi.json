{
  "name": "RegistryContract",
  "constructor": {
    "inputs": [{"name": "marketplace_fee_bps", "type": "u64"}],
    "outputs": []
  },
  "endpoints": [
    {
      "name": "registerService",
      "mutability": "mutable",
      "payableInTokens": ["EGLD"],
      "inputs": [
        {"name": "service_id", "type": "bytes"},
        {"name": "name", "type": "bytes"},
        {"name": "category", "type": "bytes"},
        {"name": "endpoint_url", "type": "bytes"},
        {"name": "pricing_model", "type": "bytes"},
        {"name": "price", "type": "BigUint"},
        {"name": "metadata_uri", "type": "bytes"}
      ],
      "outputs": []
    },
    {
      "name": "updateService",
      "mutability": "mutable",
      "inputs": [
        {"name": "service_id", "type": "bytes"},
        {"name": "new_price", "type": "BigUint"},
        {"name": "active", "type": "bool"}
      ],
      "outputs": []
    },
    {
      "name": "deregisterService",
      "mutability": "mutable",
      "inputs": [{"name": "service_id", "type": "bytes"}],
      "outputs": []
    },
    {
      "name": "setMarketplaceFee",
      "mutability": "mutable",
      "inputs": [{"name": "fee_bps", "type": "u64"}],
      "outputs": []
    }
  ],
  "views": [
    {
      "name": "getService",
      "mutability": "readonly",
      "inputs": [{"name": "service_id", "type": "bytes"}],
      "outputs": [{"type": "optional<ServiceRecord>", "multi_result": true}]
    },
    {
      "name": "getServicesByProvider",
      "mutability": "readonly",
      "inputs": [{"name": "provider", "type": "Address"}],
      "outputs": [{"type": "variadic<bytes>", "multi_result": true}]
    },
    {
      "name": "serviceExists",
      "mutability": "readonly",
      "inputs": [{"name": "service_id", "type": "bytes"}],
      "outputs": [{"type": "bool"}]
    },
    {
      "name": "getMarketplaceFeeBps",
      "mutability": "readonly",
      "inputs": [],
      "outputs": [{"type": "u64"}]
    }
  ],
  "types": {
    "ServiceRecord": {
      "type": "struct",
      "fields": [
        {"name": "provider", "type": "Address"},
        {"name": "name", "type": "bytes"},
        {"name": "category", "type": "bytes"},
        {"name": "endpoint_url", "type": "bytes"},
        {"name": "pricing_model", "type": "bytes"},
        {"name": "price", "type": "BigUint"},
        {"name": "metadata_uri", "type": "bytes"},
        {"name": "stake", "type": "BigUint"},
        {"name": "active", "type": "bool"},
        {"name": "registered_at", "type": "u64"}
      ]
    }
  }
}
