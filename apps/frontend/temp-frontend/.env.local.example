# ============================================================
# AgentBazaar Frontend — .env.local
# Copy to .env.local and fill in values after deploy
# ============================================================

# Backend NestJS API
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# MultiversX Network
NEXT_PUBLIC_MVX_NETWORK=devnet
NEXT_PUBLIC_MVX_API=https://devnet-api.multiversx.com
NEXT_PUBLIC_MVX_EXPLORER=https://devnet-explorer.multiversx.com

# Contract addresses (auto-filled by devnet/update-env.sh after deploy)
NEXT_PUBLIC_REGISTRY_CONTRACT=
NEXT_PUBLIC_ESCROW_CONTRACT=
NEXT_PUBLIC_REPUTATION_CONTRACT=

# WalletConnect v2 Project ID
# Get free at: https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=
