# ── MultiversX Network ──────────────────────────────────────────────
# Options: mainnet | devnet | testnet
MVX_NETWORK=devnet

# Smart Contract Addresses (filled by deploy.sh)
REGISTRY_CONTRACT_ADDRESS=
ESCROW_CONTRACT_ADDRESS=
REPUTATION_CONTRACT_ADDRESS=

# ── Server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Database (Postgres — for production) ────────────────────────────
POSTGRES_URL=postgresql://user:pass@localhost:5432/agentbazaar

# ── Cache (Redis — for production) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Fee collector ───────────────────────────────────────────────────
FEE_COLLECTOR_ADDRESS=erd1...
