# ============================================================
# AgentBazaar Backend — .env
# Copy to .env and fill in values after deploy
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# MultiversX
MVX_NETWORK=devnet
MVX_API_URL=https://devnet-api.multiversx.com
MVX_CHAIN_ID=D

# Contract addresses (auto-filled by devnet/update-env.sh after deploy)
REGISTRY_CONTRACT_ADDRESS=
ESCROW_CONTRACT_ADDRESS=
REPUTATION_CONTRACT_ADDRESS=

# SC MCP — MultiversX Smart Contract MCP Server
# Path to PEM wallet used by the backend for signing transactions
# Generate with: mxpy wallet new --format pem --outfile=wallet/backend.pem
MVX_WALLET_PEM_PATH=./wallet/backend.pem
# Or provide PEM content inline (overrides path)
MVX_WALLET_PEM_CONTENT=

# This backend's public URL (used in UCP discovery endpoint)
API_BASE_URL=http://localhost:3001

# x402 payment verification
# Set to 'true' to require on-chain escrow proof before executing tasks
X402_REQUIRE_ESCROW=false

# Event polling interval (ms)
EVENT_POLL_INTERVAL_MS=2000

# CORS origin
CORS_ORIGIN=http://localhost:3000
