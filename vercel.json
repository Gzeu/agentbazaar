{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "agentbazaar-frontend",
  "builds": [
    {
      "src": "apps/frontend/temp-frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/frontend/temp-frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_BACKEND_URL":           "@agentbazaar_backend_url",
    "NEXT_PUBLIC_MVX_NETWORK":           "devnet",
    "NEXT_PUBLIC_MVX_API":               "https://devnet-api.multiversx.com",
    "NEXT_PUBLIC_WC_PROJECT_ID":         "@walletconnect_project_id",
    "NEXT_PUBLIC_REGISTRY_CONTRACT":     "@registry_contract",
    "NEXT_PUBLIC_ESCROW_CONTRACT":       "@escrow_contract",
    "NEXT_PUBLIC_REPUTATION_CONTRACT":   "@reputation_contract"
  },
  "framework": "nextjs"
}
